<script>
    const firebaseConfig = { apiKey: "AIzaSyBeMsSLTbpmjzd7HrVKjhFIVAQ_goJsLUg", authDomain: "flat-chat-fa830.firebaseapp.com", databaseURL: "https://flat-chat-fa830-default-rtdb.europe-west1.firebasedatabase.app", projectId: "flat-chat-fa830" };
    firebase.initializeApp(firebaseConfig);
    const db = firebase.database();
    const rootNick = "BenMasum";

    const rolePriority = { 
    "Kurucu": 100, "KURUCU": 100,
    "Yönetici": 90, "YÖNETİCİ": 90, "Yonetici": 90,
    "Admin": 80, "ADMİN": 80,
    "Teknik Servis": 70, "TEKNİK SERVİS": 70, "Teknik Ekip": 70,
    "Dj": 60, "DJ": 60,
    "Üye": 20, "ÜYE": 20, "Uye": 20,
    "Misafir": 10, "MİSAFİR": 10, "Misafir": 10 
};


    let myName = sessionStorage.getItem("filiz_chat_nick") || "";
let loginTime = Date.now(); // Sayfa yüklendiği anın zamanını tutar
    let currentColor = localStorage.getItem("filiz_chat_color") || "#00f2ff";
    let isVerified = false, fontSize = 14, myRole = "Misafir", isBold = false, isItalic = false;
    let myPerms = {}; let allRoles = {}; let draggies = [];
    const widgetIds = ['chat-widget', 'input-widget', 'online-widget', 'login-widget', 'tools-widget', 'count-widget', 'btn-ban-list'];

    window.onload = () => { 
        initEmojis(); 
        loadLayout(); 
        fetchRolesAndUsers(); 
        checkBanStatus();
        document.getElementById('current-color-btn').style.background = currentColor;

        if (!myName) {
            const randomId = Math.floor(1000 + Math.random() * 9000);
            myName = "Guest" + randomId;
            sessionStorage.setItem("filiz_chat_nick", myName);
        }
        startAuth(); 
startCounter(); // Sayacı başlat
    };

    function loadMessages() {
    const win = document.getElementById('chat-window');
    if (!win) return; // Eğer chat penceresi yoksa dur
    db.ref('messages').off(); 
    win.innerHTML = "";

    // ONAY KONTROLÜ
    if (!isVerified) {
        win.innerHTML = `<div class="system-msg" style="border:none; background:none; color:#ff4b2b;">🔒 Sohbeti görmek için onay bekleniyor...</div>`;
        return;
    }
    
    db.ref('messages').limitToLast(50).on('child_added', s => {
        const d = s.val();
        // GÜÇLENDİRİLMİŞ FİLTRE:
    // 1. Eğer mesajın zamanı girişinden önceyse GÖSTERME
    // 2. Eğer mesajın zamanı hiç yoksa (eski mesaj demektir) yine GÖSTERME
    if (!d.timestamp || d.timestamp < loginTime) {
        return; 
    }
        // 1. EĞER YENİ GELEN BİR SİSTEM MESAJI DEĞİLSE, ESKİ SİSTEM MESAJINI HEMEN SİL
        const oldSystemMsg = win.querySelector('.system-msg');
        if (oldSystemMsg && d.type !== "system") {
            oldSystemMsg.remove();
        }

        const mRow = document.createElement('div');
        mRow.id = "msg-" + s.key;
        
        // --- SİSTEM MESAJI BLOĞU ---
        if(d.type === "system") {
            mRow.className = "system-msg";
            mRow.innerText = d.m;
            win.prepend(mRow);

            // 2. SİSTEM MESAJI 10 SANİYE SONRA KENDİLİĞİNDEN SİLİNSİN
            setTimeout(() => {
                const target = document.getElementById("msg-" + s.key);
                if (target) {
                    target.style.transition = "opacity 0.8s";
                    target.style.opacity = "0";
                    setTimeout(() => target.remove(), 800);
                }
            }, 10000); // 10 saniye
            
            return; // Sistem mesajıysa burada dur, aşağıya (normal mesaj kısmına) geçme
        }

        // --- NORMAL MESAJ BLOĞU ---
        mRow.className = "chat-msg-row";
        const nCol = d.uc || d.c || "#00f2ff";
        const italicStyle = d.i ? "font-style: italic; display: inline-block; transform: skewX(-15deg); margin-left: 3px;" : "";
        
        mRow.style.cssText = `color:${d.c}; font-weight:${d.b ? 'bold' : 'normal'}; font-size:${fontSize}px; margin-bottom: 5px;`;
        mRow.innerHTML = `<b style="color:${nCol}; margin-right: 5px; font-style: normal;">${d.u} :</b><span style="${italicStyle}">${d.m}</span>`;
        
        mRow.oncontextmenu = (e) => createContextMenu(e, { msgKey: s.key, name: d.u });
        win.prepend(mRow);
    });

        
        db.ref('messages').on('child_removed', s => { 
            const el = document.getElementById("msg-" + s.key); 
            if(el) el.remove(); 
        });
    }



    document.getElementById('msg').onkeypress = async (e) => { 
    if(e.key === "Enter" && e.target.value.trim() !== "") { 
        if(isVerified) { 
            db.ref('messages').push().set({ 
                u: myName, 
                m: e.target.value, 
                c: currentColor, 
                uc: currentColor, 
                b: isBold, 
                i: isItalic,
                timestamp: Date.now() // Mesajın atıldığı tam saniye
            }); 
            e.target.value = ""; 
        } else {
            alert("Sohbet izniniz henüz onaylanmamış!");
        }
    } 
};

// Dinleyici Sayısını Dinleyen Fonksiyon
    function startCounter() {
        const countRef = db.ref('presence');
        
        countRef.on('value', (snapshot) => {
            // snapshot.numChildren() presence altındaki toplam kayıt sayısını verir
            const totalUsers = snapshot.numChildren();
            
            const countElement = document.getElementById('total-user-count');
            if (countElement) {
                countElement.innerText = totalUsers || 0;
            }
        });
    }

    function loadLayout() {
    db.ref('layout').once('value', s => {
        const d = s.val() || {};
        widgetIds.forEach(id => {
            const el = document.getElementById(id);
            if (el && d[id]) {
                // Koordinatları ve boyutları px olarak uygula
                el.style.left = d[id].x + "px";
                el.style.top = d[id].y + "px";
                el.style.width = d[id].w + "px";
                el.style.height = d[id].h + "px";
                // Önemli: Transform kalıntılarını sıfırla
                el.style.transform = "none"; 
            }
            if (el) el.style.opacity = "1";
        });
    });
}


function setupPresence(uid) {
    // Kullanıcının online olduğu konum
    const userStatusRef = db.ref('presence/' + uid);

    // Firebase'in özel .info/connected yolu: Bağlantı durumunu kontrol eder
    db.ref('.info/connected').on('value', (snapshot) => {
        if (snapshot.val() === false) {
            return; // Bağlantı yoksa bir şey yapma
        }

        // Bağlantı koptuğunda (tarayıcı kapandığında) yapılacak işlem:
        // Sunucuya "benim verimi SİL" talimatı veriyoruz
        userStatusRef.onDisconnect().remove().then(() => {
            // Bağlantı şu an aktif, online verisini yazalım
            userStatusRef.set({
                name: uid,
                role: myRole,
                color: currentColor,
                lastSeen: firebase.database.ServerValue.TIMESTAMP
            });
        });
    });
}

    async function startAuth() {
    const presenceRef = db.ref('presence/' + myName);
    presenceRef.onDisconnect().remove();

    // Kullanıcı verilerini ve onay durumunu dinle
    db.ref('users/' + myName).on('value', async s => {
        const ud = s.val() || {};
        myRole = ud.role || "Misafir";
        

// YENİ EKLE: Yetkileri Firebase'den çek
    if (myRole !== "Kurucu") {
        const pSnap = await db.ref('permissions/' + myRole).once('value');
        myPerms = pSnap.val() || {};
    } else {
        // Kurucu ise tüm yetkileri true yap
        myPerms = { canAccessAdmin: true, canBan: true, canKick: true };
    }

        // Presence tablosundaki anlık durumu dinle
        db.ref('presence/' + myName).on('value', ps => {
            const pd = ps.val() || {};
            const isF = ud.isVerified === true;
            const isV = pd.tempVerify === true;
            isVerified = (isF || isV); 

            const authBtn = document.getElementById('auth-btn');
            const msgInput = document.getElementById('msg');
            const toolsWidget = document.getElementById('tools-widget');

            if (ud.password) {
                authBtn.innerText = "👤 " + myName;
                authBtn.style.color = "#00fc00";
            } else {
                authBtn.innerText = "GİRİŞ YAP";
            }

            if (isVerified) {
                if(msgInput) { msgInput.disabled = false; msgInput.placeholder = "Mesajınızı yazın..."; }
                if(toolsWidget) { toolsWidget.style.opacity = "1"; toolsWidget.style.pointerEvents = "auto"; }
            } else {
                if(msgInput) { msgInput.disabled = true; msgInput.placeholder = "Onay bekleniyor..."; }
                if(toolsWidget) { toolsWidget.style.opacity = "0.3"; toolsWidget.style.pointerEvents = "none"; }
            }
            
            // Onay durumu her değiştiğinde mesaj alanını tazele
            loadMessages();
        });

        // Online listesine kendini kaydet
        presenceRef.set({
            name: myName,
            role: myRole,
            isVerified: ud.isVerified || false,
            tempVerify: false,
            color: currentColor,
            lastSeen: firebase.database.ServerValue.TIMESTAMP
        });
    });

    loadUsers();
}

function loadUsers() {
    db.ref('presence').on('value', s => {
        const list = document.getElementById('user-list'); 
        if(!list) return;
        list.innerHTML = "";
        
        let usersArray = [];

        // 1. Önce tüm kullanıcıları bir diziye topla
        s.forEach(u => {
            const ud = u.val();
            if(ud.name) {
                usersArray.push(ud);
            }
        });

        // 2. Kullanıcıları rütbe önceliğine göre sırala
        usersArray.sort((a, b) => {
            const priorityA = rolePriority[a.role] || 0;
            const priorityB = rolePriority[b.role] || 0;
            return priorityB - priorityA; 
        });

        // 3. Sıralanmış listeyi ekrana bas
        usersArray.forEach(ud => {
            const isAdmin = (myRole === "Kurucu" || myRole === "Yönetici" || myRole === "Admin" || myRole === "Dj" || (myPerms && myPerms.canAccessAdmin));
            const hasP = ud.isVerified === true; 
            const hasT = ud.tempVerify === true; 
            const isApproved = (hasP || hasT); 

            // Rütbe Filtresi: Üye ve Misafir ise rütbe ismini gösterme
            const showRole = (ud.role !== "Üye" && ud.role !== "Misafir");

            const div = document.createElement('div'); 
            div.className = "online-user-row-container";
            
            let verifyClass = hasP ? 'tick-f' : (hasT ? 'tick-v' : '');
            let verifyIcon = hasP ? 'F' : (hasT ? '✓' : '');

            div.innerHTML = `
                <div class="online-user-row">
                    <div class="verify-box ${verifyClass}" onclick="quickVerify('${ud.name}', ${isApproved})">
                        ${verifyIcon}
                    </div>

                    <span class="user-name-label ${isApproved ? '' : 'unverified-text'}" 
                          style="color:${ud.color || '#fff'}; cursor:pointer;" 
                          onclick="toggleUserActions('${ud.name}')">
                        ● ${ud.name} 
                        
                        ${showRole ? `
                        <small style="opacity:0.6; font-size:10px; text-decoration: none !important; display: inline-block;">
                            [${ud.role || 'Misafir'}]
                        </small>
                        ` : ''}
                    </span>
                </div>

                ${isAdmin && ud.name !== myName ? `
                <div id="actions-${ud.name.replace(/\s+/g, '_')}" class="quick-action-panel">
                    <div class="action-btn btn-kick" onclick="kickUser('${ud.name}')">SOHBETTEN AT</div>
                    <div class="action-btn btn-ban" onclick="quickBanUser('${ud.name}')">KALICI BANLA</div>
                </div>
                ` : ''}
            `;
            list.appendChild(div);
        });

        const countEl = document.getElementById('total-user-count');
        if (countEl) countEl.innerText = usersArray.length;
    });
}

    function createContextMenu(e, t = null) { 
    e.preventDefault(); 
    const menu = document.getElementById('context-menu'); 
    menu.innerHTML = ""; 

    // YETKİ KONTROLLERİ (Admin panelindeki checkbox isimlerine göre)
    const canSeeAdminPanel = (myRole === "Kurucu" || myPerms.canAccessAdmin);
    const canClear = (myRole === "Kurucu" || myPerms.canClearChat); // Sohbet Temizleme Yetkisi
    const canDelete = (myRole === "Kurucu" || myPerms.canDeleteMsgs); // Tekil Mesaj Silme
    const canBan = (myRole === "Kurucu" || myPerms.canBan); // Banlama Yetkisi
    const canMove = (myRole === "Kurucu" || myRole === "Teknik Servis"); // Taşıma/Boyutlandırma

    // 1. Yönetim Paneli Butonu
    if(canSeeAdminPanel) {
        addMenuItem(menu, "⚙ YÖNETİM PANELİ", () => window.open('admin.html', '_blank'), "menu-success"); 
    }

    // 2. Mesaj Silme (Sadece bir mesajın üzerindeyken çıkar)
