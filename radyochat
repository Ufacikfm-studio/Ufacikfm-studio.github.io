    // Eğer misafir olarak bağlıysa eski misafir kaydını temizle
    if(myName && myName.startsWith("Guest")) {
        await db.ref('presence/' + myName).remove();
    }

    const userRef = db.ref('users/' + n);
    const snapshot = await userRef.once('value');
    const userData = snapshot.val();

    if (userData) {
        if (userData.password === p) {
            // Başarılı Giriş: Bilgileri kaydet ve sayfayı tazele
            sessionStorage.setItem("filiz_chat_nick", n);
            // Opsiyonel: Giriş yapınca rengini de güncelle
