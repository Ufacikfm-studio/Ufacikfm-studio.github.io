async function quickBanUser(tNick) {
    // 1. Hedefin verilerini (rütbesini) çek
    const targetSnap = await db.ref('presence/' + tNick).once('value');
    const targetData = targetSnap.val();
    
    if(!targetData) return alert("Kullanıcı aktif listede bulunamadı.");

    // Rütbe Puanlarını Hesapla
    const myRank = rolePriority[myRole] || 0;
    const targetRank = rolePriority[targetData.role] || 0;

    // --- HİERARŞİ SİSTEMİ GÜNCELLEMESİ ---
    // Kurucu her zaman banlayabilir, ama diğerleri kendi rütbesini veya üstünü banlayamaz.
    if (myRole !== "Kurucu") {
        if (myRank < targetRank) {
            alert(`Hata: ${tNick} sizden üst bir rütbede (${targetData.role}). İşlem engellendi!`);
            return;
        }
        if (myRank === targetRank) {
            alert(`Hata: ${tNick} ile aynı rütbedesiniz. Kendi rütbe arkadaşınızı banlayamazsınız!`);
            return;
        }
    }

    if(!confirm(`${tNick} kullanıcısını banlamak istediğinize emin misiniz?`)) return;

    // 2. IP bilgisini user_registry'den al
    const regSnap = await db.ref('user_registry/' + tNick).once('value');
    if(regSnap.exists() && regSnap.val().last_ip) {
        const safeIp = regSnap.val().last_ip.replace(/\./g, '_');
        
        // Veritabanına Ban Kaydı At
        await db.ref('banned_ips/' + safeIp).set({ 
            nick: tNick, 
            bannedBy: myName, 
            date: Date.now() 
        });

        // --- LİSTEDEN ANINDA SİLME ---
        // Kullanıcıyı online listesinden (presence) anında siler
        await db.ref('presence/' + tNick).remove();
        
        // --- SESSİZ BAN GÜNCELLEMESİ ---
        // Buraya sistem mesajı eklemiyoruz ki sayfa yenilendikçe o uyarılar birikmesin.
        
        alert(`${tNick} başarıyla uzaklaştırıldı.`);
    } else {
        alert("Kullanıcının IP adresi sistemde kayıtlı değil, işlem yapılamadı.");
    }
}

