async function quickVerify(tNick) {
    const currentRole = (myRole || "").toLowerCase().trim();
    const adminRanks = ["kurucu", "admin", "yönetici", "teknik ekip", "teknik servis"];
    
    const isAdmin = adminRanks.includes(currentRole);
    const isDJ = (currentRole === "dj");

    if (!isAdmin && !isDJ) return; // Yetki yoksa sessizce çık

    // Veritabanından anlık durumu çek
    const presenceSnap = await db.ref('presence/' + tNick).once('value');
    const pData = presenceSnap.val() || {};
    
    const hasF = pData.isVerified === true;       
    const hasCheck = pData.tempVerify === true;    

    // --- DJ MANTIĞI (Aç/Kapat) ---
    if (isDJ) {
        await db.ref('presence/' + tNick).update({ 
            tempVerify: !(hasF || hasCheck) // Varsa kaldır, yoksa ekle
        });
        return;
    }

    // --- ÜST YÖNETİM DÖNGÜSÜ (✓ -> F -> SIFIRLA) ---
    if (isAdmin) {
        // 1. DURUM: Hiçbir şey yoksa -> GEÇİCİ ONAY (✓)
        if (!hasF && !hasCheck) {
            await db.ref('presence/' + tNick).update({ 
                tempVerify: true,
                isVerified: false 
            });
        } 
        // 2. DURUM: Geçici varsa -> KALICI ONAY (F)
        else if (hasCheck && !hasF) {
            await db.ref('users/' + tNick).update({ 
                isVerified: true, 
                role: "Üye" 
            });
            await db.ref('presence/' + tNick).update({ 
                isVerified: true, 
                tempVerify: false, 
                role: "Üye" 
            });
        }
        // 3. DURUM: Kalıcı varsa -> HER ŞEYİ SIFIRLA (Onaysız Misafir)
        else if (hasF) {
            await db.ref('users/' + tNick).update({ isVerified: false, role: "Misafir" });
            await db.ref('presence/' + tNick).update({ isVerified: false, tempVerify: false, role: "Misafir" });
        }
    }
}

    function setEditMode(type) {
        if (myRole !== "Kurucu" && myRole !== "Teknik Servis") return alert("Yetkiniz yok!");
    // Önce varsa eski kalkanları ve sürükleme özelliklerini temizle
    draggies.forEach(d => d.destroy()); 
    draggies = [];
    document.querySelectorAll('.widget-overlay').forEach(el => el.remove());

    widgetIds.forEach(id => {
        const el = document.getElementById(id);
        if(!el) return;

        el.classList.remove('edit-mode-active', 'resize-mode-active');

        if(type === 'move') {
            el.classList.add('edit-mode-active');

            // --- KALKAN EKLEME (Tıklamaları engeller) ---
            const overlay = document.createElement('div');
            overlay.className = 'widget-overlay';
            el.appendChild(overlay);

            const draggie = new Draggabilly(el, {
    handle: '.widget-overlay',
    containment: false // Sayfa dışına taşmayı engellemek için bazen bunu true yaparlar, false kalsın.
});

            draggie.on('dragEnd', function() { 
                db.ref('layout/'+id).update({ x: this.position.x, y: this.position.y }); 
            });
            draggies.push(draggie);
        } else { 
            el.classList.add('resize-mode-active'); 
        }
    });
}


    function saveAndLock() {
    // 1. Draggabilly örneklerini tek tek dönüp son konumlarını bulalım
    draggies.forEach(d => {
        // d.element sürüklenen widget'tır
        const id = d.element.id;
        
        // Draggabilly'nin içindeki gerçek x ve y (transform dahil hesaplanmış)
        // Eğer sürüklenmediyse offset değerlerini al
        const xPos = d.position.x;
        const yPos = d.position.y;
        
        const w = d.element.offsetWidth;
        const h = d.element.offsetHeight;

        // Firebase'e kaydet
        db.ref('layout/' + id).update({
            x: Math.round(xPos),
            y: Math.round(yPos),
            w: Math.round(w),
            h: Math.round(h)
        });

        // Draggabilly'yi kapat
        d.destroy();
    });

    // 2. Eğer sürüklenmemiş ama boyutu değişmiş (resize) widgetlar varsa onları da kapsayalım
    widgetIds.forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        
        // Sadece resize modundakiler için (draggies içinde olmayanlar)
        if(el.classList.contains('resize-mode-active')) {
             db.ref('layout/'+id).update({
                w: el.offsetWidth,
                h: el.offsetHeight,
                x: parseInt(el.style.left) || el.offsetLeft,
                y: parseInt(el.style.top) || el.offsetTop
            });
        }
        
        el.classList.remove('edit-mode-active', 'resize-mode-active');
    });

    // 3. Kalkanları temizle
    document.querySelectorAll('.widget-overlay').forEach(el => el.remove());
    draggies = [];

    alert("Yerleşim kaydedildi!");
    location.reload(); 
}


